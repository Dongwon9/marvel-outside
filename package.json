{
  "name": "marvel-outside",
  "version": "1.0.0",
  "private": true,
  "workspaces": [
    "frontend",
    "backend"
  ],
  "scripts": {
    "dev": "docker compose up",
    "down": "docker compose down",
    "start:dev:be": "pnpm -F backend start:dev",
    "start:dev:fe": "pnpm -F frontend start:dev",
    "start:dev": "pnpm -r start:dev",
    "build": "pnpm -r build",
    "lint": "pnpm -r lint",
    "lint:fe": "pnpm -F frontend lint",
    "lint:be": "pnpm -F backend lint",
    "test": "pnpm -r test",
    "test:integration": "pnpm -r test:integration",
    "test:all": "pnpm -r  test:all",
    "db:push:dev": "pnpm -F backend db:push:dev",
    "db:reset:dev": "pnpm -F backend db:reset:dev"
  },
  "devDependencies": {
    "@eslint/js": "^9.39.3",
    "@types/node": "^25.3.0",
    "ajv": "^6.14.0",
    "eslint": "^9.39.3",
    "eslint-plugin-import": "^2.32.0",
    "eslint-plugin-prettier": "^5.5.5",
    "eslint-plugin-unused-imports": "^4.4.1",
    "globals": "^17.3.0",
    "prettier": "^3.8.1",
    "typescript": "^5.9.3",
    "typescript-eslint": "^8.56.0"
  },
  "packageManager": "pnpm@10.30.2+sha512.36cdc707e7b7940a988c9c1ecf88d084f8514b5c3f085f53a2e244c2921d3b2545bc20dd4ebe1fc245feec463bb298aecea7a63ed1f7680b877dc6379d8d0cb4",
  "pnpm": {
    "overrides": {
      "@eslint/eslintrc>ajv": "^6.14.0",
      "lodash@>=4.0.0 <=4.17.22": ">=4.17.23",
      "hono@<4.11.7": ">=4.11.7",
      "hono@<4.11.10": ">=4.11.10",
      "ajv@>=7.0.0-alpha.0 <8.18.0": ">=8.18.0",
      "hono@>=4.12.0 <4.12.2": ">=4.12.2",
      "rollup@>=4.0.0 <4.59.0": ">=4.59.0",
      "minimatch@>=10.0.0 <10.2.3": ">=10.2.3",
