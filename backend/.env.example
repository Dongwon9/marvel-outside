# Environment variables declared in this file are NOT automatically loaded by Prisma.
# Please copy this file to .env.development, .env.test, or .env.production and fill in the values.

# Development: Local PostgreSQL (docker-compose)
# TEST: Same PostgreSQL with separate schema
# Production: Prisma Postgres

# Prisma supports the native connection string format for PostgreSQL
# See the documentation for all the connection string options: https://pris.ly/d/connection-strings

# For local development: postgres://user:password@localhost:5432/marvel_dev
# Format: postgresql://user:password@host:port/database
DATABASE_URL="postgresql://marvel:marvel_password@localhost:5432/marvel_dev"

# Redis Configuration
REDIS_URL="redis://:your-redis-password@localhost:6379"

# JWT Configuration
JWT_SECRET="your-secret-key-change-this-in-production"
JWT_EXPIRES_IN="15m"
JWT_REFRESH_SECRET="your-refresh-secret-key-change-this-in-production"
JWT_REFRESH_EXPIRES_IN="7d"
REFRESH_TOKEN_TTL="2592000"

# Email Configuration
# Set EMAIL_ENABLED to "true" and configure the SMTP settings below in production
EMAIL_ENABLED="false"
EMAIL_HOST="smtp.example.com"
EMAIL_PORT="587"
EMAIL_USER="your-smtp-user"
EMAIL_PASS="your-smtp-password"
EMAIL_FROM="Marvel Outside <noreply@example.com>"
# Frontend verification page base URL (without query string).
# The verification link will be generated as: `${EMAIL_VERIFY_URL_BASE}?token=...`
EMAIL_VERIFY_URL_BASE="http://localhost:5173/verify-email"
